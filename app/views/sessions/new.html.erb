<div class="session-page">
  <div class="session-wrap">
    <div class="session-card">

      <h1 class="session-title">ログイン</h1>

      <%= form_with url: session_path, method: :post, local: true do %>

        <div class="session-field">
          <label class="session-label">メールアドレス</label>
          <%= email_field_tag :email, params[:email], class: "session-input" %>
        </div>

        <div class="session-field">
          <label class="session-label">パスワード</label>
          <%= password_field_tag :password, nil, class: "session-input" %>
        </div>

        <%= submit_tag "ログイン", class: "session-btn session-btn--login" %>

      <% end %>

      <%= link_to "新規登録", new_user_path,
            class: "session-btn session-btn--signup",
            style: "display:block;text-align:center;" %>

    </div>
  </div>
</div>