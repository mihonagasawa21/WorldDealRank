<div class="session-page">
  <div class="session-wrap">
    <div class="session-card">

      <h1 class="session-title">新規登録</h1>

      <%= form_with model: @user, url: users_path do |f| %>

        <% if @user.errors.any? %>
          <div class="post-errors post-errors--inline">
            <div class="post-errors__title">入力エラーがあります</div>
            <div class="post-errors__text">
              <%= @user.errors.full_messages.join("／") %>
            </div>
          </div>
        <% end %>

        <div class="session-field">
          <%= f.label :username, "ユーザー名", class: "session-label" %>
          <%= f.text_field :username, class: "session-input" %>
        </div>

        <div class="session-field">
          <%= f.label :email, "メールアドレス", class: "session-label" %>
          <%= f.email_field :email, class: "session-input" %>
        </div>

        <div class="session-field">
          <%= f.label :password, "パスワード", class: "session-label" %>
          <%= f.password_field :password, class: "session-input" %>
        </div>

        <div class="session-field">
          <%= f.label :password_confirmation, "パスワード確認", class: "session-label" %>
          <%= f.password_field :password_confirmation, class: "session-input" %>
        </div>

        <div style="margin-top:16px;">
          <%= f.submit "登録する",
                class: "session-btn session-btn--login" %>
        </div>

      <% end %>

      <%= link_to "ログインへ",
            new_session_path,
            class: "session-btn session-btn--signup" %>

    </div>
  </div>
</div>