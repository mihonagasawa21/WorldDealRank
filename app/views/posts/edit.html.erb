<div class="posts-page">
  <h1 class="posts-title">投稿を編集</h1>

  <%= form_with model: @post, local: true, class: "post-form" do |f| %>
    <% if @post.errors.any? %>
      <div class="post-errors">
        <div class="post-errors__title">入力エラーがあります</div>
        <ul class="post-errors__list">
          <% @post.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="post-field">
      <%= f.label :title, "タイトル", class: "post-label" %>
      <%= f.text_field :title, class: "post-input" %>
    </div>

    <div class="post-field">
      <%= f.label :country_id, "国", class: "post-label" %>
      <%= f.collection_select :country_id, Country.order(:name_ja), :id, :name_ja, { include_blank: "選択してください" }, class: "post-select" %>
    </div>

    <div class="post-field">
      <%= f.label :body, "本文", class: "post-label" %>
      <%= f.text_area :body, rows: 8, class: "post-textarea" %>
    </div>

    <div class="post-field">
      <%= f.label :attachments, "添付", class: "post-label" %>
      <%= f.file_field :attachments, multiple: true, class: "post-file" %>
    </div>

    <div class="post-actions">
      <%= f.submit "更新する", class: "post-btn" %>
    </div>
  <% end %>
</div>