<%= form_with model: post, class: "post-form" do |f| %>
  <% if post.errors.any? %>
  <div class="post-errors post-errors--inline">
    <div class="post-errors__title">入力エラーがあります</div>
    <div class="post-errors__text">
      <%= post.errors.full_messages.join("／") %>
    </div>
  </div>
<% end %>

  <div class="post-field">
    <%= f.label :country_id, "国", class: "post-label" %>
    <%= f.collection_select :country_id, @countries, :id, :name_ja,
          { include_blank: "選択してください" },
          { class: "post-select" } %>
  </div>

  <div class="post-field">
    <%= f.label :title, "題名", class: "post-label" %>
    <%= f.text_field :title,
          class: "post-input",
          placeholder: "無題",
          value: (post.title == "無題" ? "" : post.title) %>
  </div>

  <div class="post-field">
    <%= f.label :body, "本文", class: "post-label" %>
    <%= f.text_area :body, rows: 10, class: "post-textarea" %>
  </div>

  <div class="post-field"
      data-controller="tags"
      data-tags-initial-value="<%= post.tags.map(&:name).join(' ') %>">

    <%= f.label :tag_names, "ハッシュタグ", class: "post-label" %>

    <div class="post-tagui">
      <input type="text"
            class="post-input post-tagui__input"
            placeholder="タグを入力して追加"
            data-tags-target="input">

      <button type="button"
              class="post-btn post-tagui__btn"
              data-action="tags#add">
        追加
      </button>
    </div>

    <div class="post-tagui__chips" data-tags-target="chips"></div>

    <%= f.hidden_field :tag_names, value: "", data: { tags_target: "hidden" } %>
  </div>


  <div class="post-field">
    <%= f.label :attachments, "写真・動画を添付", class: "post-label" %>
    <%= f.file_field :attachments, multiple: true, class: "post-file" %>
  </div>

  <% if post.persisted? && post.attachments.attached? %>
    <div class="post-note">
      既存の添付は保持されます。削除機能は次段で追加できます。
    </div>
  <% end %>

  <div class="post-actions">
    <%= f.submit "投稿", class: "post-btn" %>
  </div>
<% end %>