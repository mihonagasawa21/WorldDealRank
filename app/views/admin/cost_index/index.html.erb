<h1>コスト指数 管理画面</h1>

<% if flash[:notice].present? %>
  <p style="color: green; font-weight: bold;"><%= flash[:notice] %></p>
<% end %>

<% if flash[:alert].present? %>
  <p style="color: red; font-weight: bold;"><%= flash[:alert] %></p>
<% end %>

<p>
  <%= button_to "本番データ更新（MOFA・人気・FX・PPP・再計算）",
        refresh_admin_cost_index_path,
        method: :post,
        data: { turbo: false } %>
</p>

<hr>

<h2>集計</h2>

<table border="1" cellpadding="8" cellspacing="0">
  <tr>
    <th>総国数</th>
    <td><%= @total_count %></td>
  </tr>
  <tr>
    <th>final_indexあり</th>
    <td><%= @final_index_count %></td>
  </tr>
  <tr>
    <th>jp_resident_countあり</th>
    <td><%= @resident_count_count %></td>
  </tr>
  <tr>
    <th>calculated_atあり</th>
    <td><%= @calculated_at_count %></td>
  </tr>
  <tr>
    <th>last_errorあり</th>
    <td><%= @last_error_count %></td>
  </tr>
  <tr>
    <th>最新 calculated_at</th>
    <td><%= @latest_calculated_at || "-" %></td>
  </tr>
  <tr>
    <th>fx_rate_usdあり</th>
    <td><%= @fx_count %></td>
  </tr>
  <tr>
    <th>ppp_lcu_per_intlあり</th>
    <td><%= @ppp_count %></td>
  </tr>
  <tr>
    <th>plrあり</th>
    <td><%= @plr_count %></td>
  </tr>
  <tr>
    <th>tourism_coefあり</th>
    <td><%= @tourism_count %></td>
  </tr>
</table>

<hr>

<h2>問題がありそうな国</h2>

<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr>
      <th>国名</th>
      <th>final_index</th>
      <th>jp_resident_count</th>
      <th>calculated_at</th>
      <th>last_error</th>
    </tr>
  </thead>
  <tbody>
    <% @problem_countries.each do |c| %>
      <tr>
        <td><%= c.name_ja.presence || c.name_en.presence || c.iso3 || c.id %></td>
        <td><%= c.final_index.nil? ? "-" : c.final_index %></td>
        <td><%= c.jp_resident_count.nil? ? "-" : c.jp_resident_count %></td>
        <td><%= c.calculated_at || "-" %></td>
        <td style="max-width: 500px; white-space: pre-wrap;"><%= c.last_error.presence || "-" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<hr>

<h2>world表示の確認用</h2>

<table border="1" cellpadding="6" cellspacing="0">
  <thead>
    <tr>
      <th>国名</th>
      <th>指数(final_index_ui)</th>
      <th>安さ評価(cheap)</th>
      <th>人気評価(popular)</th>
      <th>総合点(recommend)</th>
      <th>final_index</th>
      <th>jp_resident_count</th>
    </tr>
  </thead>
  <tbody>
    <% @sample_world_rows.each do |c| %>
      <% score = @score_map[c.id] || {} %>
      <tr>
        <td><%= c.name_ja.presence || c.name_en.presence || c.iso3 || c.id %></td>
        <td><%= c.final_index_ui %></td>
        <td><%= score[:cheap].nil? ? "-" : score[:cheap] %></td>
        <td><%= score[:popular].nil? ? "測定不能" : score[:popular] %></td>
        <td><%= score[:recommend].nil? ? "-" : score[:recommend] %></td>
        <td><%= c.final_index.nil? ? "-" : c.final_index %></td>
        <td><%= c.jp_resident_count.nil? ? "-" : c.jp_resident_count %></td>
      </tr>
    <% end %>
  </tbody>
</table>